#!/usr/bin/env bash
# Shared helpers for shared-meilisearch. Sourced — never executed directly.
set -euo pipefail

# 16 random bytes -> 32 hex chars. Used for the master key. No openssl dep.
generate_key() {
  od -An -tx1 -N16 /dev/urandom | tr -d ' \n'
}

validate_name() {
  local name="${1:-}"
  [[ -n "$name" ]] || return 1
  [[ "$name" =~ $PLUGIN_NAME_REGEX ]] || return 1
}

service_exists() {
  local name="$1"
  [[ -d "$PLUGIN_DATA_ROOT/$name" ]]
}

service_list() {
  [[ -d "$PLUGIN_DATA_ROOT" ]] || return 0
  local d
  for d in "$PLUGIN_DATA_ROOT"/*/; do
    [[ -d "$d" ]] || continue
    local name="${d%/}"
    name="${name##*/}"
    [[ "$name" == .* ]] && continue
    # `_meilidata` is the container's data volume; `_`-prefixed is reserved.
    [[ "$name" == _* ]] && continue
    printf '%s\n' "$name"
  done | sort
}
